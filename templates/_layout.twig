<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
    <head>
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta charset="utf-8">
        <title>
            {% if entry.slug == 'home' %}
                {% if entry.seoTitle %}
                    {{ entry.seoTitle }} |
                {% endif %}
                {{ currentSite.name }}
            {% else %}
                {{ entry.seoTitle ?? entry.title }} | {{ currentSite.name }}
            {% endif %}
        </title>
        <meta name="referrer"content="origin-when-cross-origin">
        <meta name="robots" content="index, follow">
        <meta name="viewport"content="initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover,width=device-width">
        <meta name="description" content="{{ entry.summary ?? entry.seoDescription }}">
        {% block openGraph %}
            <meta property="og:description" content="{{ entry.seoDescription }}">
            {% set previewImage = entry.seoPreviewImage.one() ?? brand.seoPreviewImage.one() %}
            {% if previewImage %}
                <meta property="og:image" content="{{ previewImage.getUrl({ format: 'jpg', height: 630, width: 1200, quality: 90 }) }}">
            {% endif %}
            <meta property="og:locale" content="{{ craft.app.language }}">
            <meta property="og:site_name" content="{{ currentSite.name }}">
            <meta property="og:title" content="{{ entry.seoTitle ?? entry.title }}">
            <meta property="og:type" content="website">
            <meta property="og:url" content="{{ entry.url }}">
        {% endblock %}
        <link rel="icon" href="/favicon.svg">
        <link rel="mask-icon" href="/mask-icon.svg" color="#1F336A">
        <link rel="apple-touch-icon" href="/apple-touch-icon.png">
        {% include '_partials/schema' %}
        {% block schema %}{% endblock %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Condensed:wght@400;700&family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
        <link href="/assets/css/style.css" rel="stylesheet" type="text/css">
        {{ craft.vite.script('src/js/index.js', false, { 'defer': true }) }}
    </head>
    <body>
        <input class="menuToggle" id="menuToggle" type="checkbox">
        {% include "_partials/banner" with {
            isNavInverted: true,
            isNavTransparent: true,
        } %}
        <div class="page">
            <main class="page__main">
                {% block content %}{% endblock %}
            </main>
            {% include '_partials/footer' %}
        </div>
        <script src="https://unpkg.com/lucide@latest"></script>
        <script>
            lucide.createIcons();
        </script>
    </body>
</html>