{% set image = section.image.one() %}
{% set imageMobile = section.imageMobile.one() ?? image %}

<section class="section hero hero--{{ section.height ?? 'fit' }} hero--width-{{ section.textWidth }} u-theme-{{ section.theme }} js-equinox">
    {% if image and imageMobile %}
        <img
            alt="{{ image.title }}"
            sizes="100vw"
            src="{{ image.url }}"
            srcset="
                {{ image.getUrl({ format: 'webp', height: 270, upscale: false, width: 480 }) }} 480w,
                {{ image.getUrl({ format: 'webp', height: 333, upscale: false, width: 592 }) }} 592w,
                {{ image.getUrl({ format: 'webp', height: 432, upscale: false, width: 768 }) }} 768w,
                {{ image.getUrl({ format: 'webp', height: 576, upscale: false, width: 1024 }) }} 1024w,
                {{ image.getUrl({ format: 'webp', height: 666, upscale: false, width: 1184 }) }} 1184w,
                {{ image.getUrl({ format: 'webp', height: 864, upscale: false, width: 1536 }) }} 1536w,
                {{ image.getUrl({ format: 'webp', height: 1152, upscale: false, width: 2048 }) }} 2048w
            "
            class="hero__backdrop hero__backdrop--desktop"
            decoding="async"
            loading="lazy"
        />
        <img
            alt="{{ image.title }}"
            sizes="100vw"
            src="{{ imageMobile.url }}"
            srcset="
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 480, width: 270 }) }} 270w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 592, width: 333 }) }} 333w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 768, width: 432 }) }} 432w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 1024, width: 576 }) }} 576w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 1184, width: 666 }) }} 666w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 1536, width: 864 }) }} 864w,
                {{ imageMobile.getUrl({ format: 'webp', upscale: false, height: 2048, width: 1152 }) }} 1152w
            "
            class="hero__backdrop hero__backdrop--mobile"
            decoding="async"
            loading="lazy"
        />
    {% endif %}
    <div class="wrapper section__inner">
        <div class="grid grid--gap-xl grid--middle l:grid--gap-xxl">
            <div class="grid__col l:grid__col--span-{{ section.textWidth == '75' ? '8' : '6'}}">
                <div class="hero__content stack stack--gap-xl">
                    <div class="stack stack--gap-m">
                        <h1 class="textSplit js-textSplit">{{ section.title }}</h1>
                        <div class="hero__text richText">
                            {{ section.text }}
                        </div>
                    </div>
                    {% if section.ctas %}
                        {% include '_partials/ctas' with { ctas: section.ctas } %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>